{
  "name": "ai-crypto-analytics-agent",
  "version": "1.0.0",
  "description": "AI-Powered Crypto Analytics Agent for Token Insights & Forecasting",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm start",
    "dev:backend": "cd backend && python simple_main.py",
    "dev:backend-uvicorn": "cd backend && uvicorn main:app --reload --port 8000",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && python -m pytest",
    "start": "npm run build && npm run start:backend",
    "start:backend": "cd backend && python simple_main.py",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && pip install fastapi uvicorn python-dotenv pydantic-settings",
    "format": "cd frontend && npm run format",
    "lint": "cd frontend && npm run lint"
  },
  "keywords": [
    "cryptocurrency",
    "ai",
    "machine-learning",
    "analytics",
    "forecasting",
    "react",
    "typescript",
    "python",
    "fastapi"
  ],
  "author": "Final Year Project Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
