COINMARKETCAP_API_KEY=4398999d-b92c-484c-ad6f-a851679a90cd
NEWS_API_KEY=0c37da84674d462a814bf59b7b3763f6

# Database Configuration
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=crypto_analytics
POSTGRES_PORT=5432

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=crypto-analytics-super-secret-key-2025-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Environment
ENVIRONMENT=development

# CORS Origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://localhost:3000

# AI/ML Settings
MODEL_UPDATE_INTERVAL=3600
PREDICTION_CACHE_TTL=1800

# Additional APIs for Enhanced Features
ALPHA_VANTAGE_API_KEY=demo
FEAR_GREED_INDEX_URL=https://api.alternative.me/fng/
CRYPTO_COMPARE_API_KEY=

# WebSocket Configuration
WEBSOCKET_ENABLED=true
WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10

# Rate Limiting
API_RATE_LIMIT_PER_MINUTE=100
API_RATE_LIMIT_BURST=20

# Caching Configuration
CACHE_DEFAULT_TTL=300
CACHE_PREDICTIONS_TTL=1800
CACHE_MARKET_DATA_TTL=60

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# Model Configuration
LSTM_SEQUENCE_LENGTH=60
LSTM_EPOCHS=100
LSTM_BATCH_SIZE=32
ARIMA_MAX_P=5
ARIMA_MAX_D=2
ARIMA_MAX_Q=5

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WEBSOCKET_URL=ws://localhost:8000/ws
REACT_APP_ENVIRONMENT=development
REACT_APP_ENABLE_ANALYTICS=false

